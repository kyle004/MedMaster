{
  "rules": {
    "presence": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'codingky@gmail.com'",
      ".indexOn": ["timestamp"]
    },
    "analytics": {
      "visits": {
        ".read": "auth != null && auth.token.email === 'codingky@gmail.com'",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      },
      "sessions": {
        ".read": "auth != null && auth.token.email === 'codingky@gmail.com'",
        ".write": "auth != null",
        ".indexOn": ["userId", "timestamp"]
      }
    },
    "userStats": {
      ".read": "auth != null && auth.token.email === 'codingky@gmail.com'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt"]
    },
    "activityFeed": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },
    "userProgress": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "bannedUsers": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'codingky@gmail.com'"
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    },
    "appConfig": {
      "inviteCode": {
        ".read": true,
        ".write": "auth != null && auth.token.email === 'codingky@gmail.com'"
      },
      "siteConfig": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email === 'codingky@gmail.com'"
      }
    }
  }
}
